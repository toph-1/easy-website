# Start local server
start_local() {
    # Check if already running
    if [ -f "$SERVER_PID_FILE" ] && kill -0 $(cat "$SERVER_PID_FILE") 2>/dev/null; then
        echo -e "${YELLOW}[!] Server already running (PID: $(cat $SERVER_PID_FILE))${NC}"
        return 0
    fi
    
    # Kill any existing servers on port
    pkill -f "python.*http.server.*$PORT" 2>/dev/null
    pkill -f "php -S.*$PORT" 2>/dev/null
    
    cd "$SITE_DIR"
    
    # Use Python3 HTTP server
    if command -v python3 &> /dev/null; then
        python3 -m http.server $PORT > /tmp/local_server.log 2>&1 &
        echo $! > "$SERVER_PID_FILE"
        sleep 1
        
        # Verify it's running
        if kill -0 $(cat "$SERVER_PID_FILE") 2>/dev/null; then
            echo -e "${GREEN}[✓] Local server started on port $PORT${NC}"
            echo -e "${GREEN}[✓] Access at: http://localhost:$PORT${NC}"
            
            # Save public URL placeholder
            echo "Local only" > "$SITE_DIR/public_url.txt"
            return 0
        else
            echo -e "${RED}[✗] Failed to start server${NC}"
            rm "$SERVER_PID_FILE"
            return 1
        fi
    else
        echo -e "${RED}[✗] Python3 not found. Install with: sudo apt install python3 -y${NC}"
        return 1
    fi
}

# Stop local server
stop_local() {
    if [ -f "$SERVER_PID_FILE" ]; then
        kill $(cat "$SERVER_PID_FILE") 2>/dev/null
        rm "$SERVER_PID_FILE"
        echo -e "${GREEN}[✓] Local server stopped${NC}"
    else
        # Try to kill by process name
        pkill -f "python.*http.server.*$PORT" && echo -e "${GREEN}[✓] Server stopped${NC}" || echo -e "${YELLOW}[!] No server running${NC}"
    fi
}

# Start Cloudflare tunnel
start_cloudflare() {
    # Check if local server is running
    if [ ! -f "$SERVER_PID_FILE" ] || ! kill -0 $(cat "$SERVER_PID_FILE") 2>/dev/null; then
        echo -e "${RED}[✗] Local server not running!${NC}"
        echo -e "${YELLOW}Start it first with option 3${NC}"
        return 1
    fi
    
    # Check if tunnel already running
    if [ -f "$TUNNEL_PID_FILE" ] && kill -0 $(cat "$TUNNEL_PID_FILE") 2>/dev/null; then
        echo -e "${YELLOW}[!] Cloudflare tunnel already running${NC}"
        return 0
    fi
    
    # Fix DNS first
    fix_dns
    
    # Ensure cloudflared is installed
    if ! install_cloudflared; then
        echo -e "${RED}[✗] Cannot proceed without cloudflared${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}[+] Starting Cloudflare tunnel...${NC}"
    echo -e "${YELLOW}This may take 10-15 seconds...${NC}"
    
    # Kill any existing cloudflared processes
    pkill -f "cloudflared.*tunnel.*$PORT" 2>/dev/null
    
    # Start tunnel with longer timeout
    timeout 30 cloudflared tunnel --url http://localhost:$PORT > /tmp/cloudflare.log 2>&1 &
    TUNNEL_PID=$!
    echo $TUNNEL_PID > "$TUNNEL_PID_FILE"
    
    # Wait for tunnel to establish
    echo -n "Connecting"
    for i in {1..15}; do
        echo -n "."
        sleep 1
        if grep -q "https://.*trycloudflare.com" /tmp/cloudflare.log 2>/dev/null; then
            echo ""
            break
        fi
    done
    echo ""
    
    # Extract public URL
    PUBLIC_URL=$(grep -o 'https://[-a-zA-Z0-9.]*trycloudflare.com' /tmp/cloudflare.log | head -1)
    
    if [ -n "$PUBLIC_URL" ]; then
        echo -e "${GREEN}════════════════════════════════════════════════${NC}"
        echo -e "${GREEN}🌍 SUCCESS! WEBSITE IS PUBLIC!${NC}"
        echo -e "${GREEN}════════════════════════════════════════════════${NC}"
        echo -e "${YELLOW}Public URL: ${GREEN}$PUBLIC_URL${NC}"
        echo -e "${YELLOW}Local URL:  ${GREEN}http://localhost:$PORT${NC}"
        echo -e "${GREEN}════════════════════════════════════════════════${NC}"
        
        # Save URL
        echo "$PUBLIC_URL" > "$SITE_DIR/public_url.txt"
        
        # Generate QR code if qrencode is installed
        if command -v qrencode &> /dev/null; then
            echo -e "${YELLOW}QR Code for mobile access:${NC}"
            qrencode -t ansiutf8 "$PUBLIC_URL" 2>/dev/null
        fi
        
        # Show how to stop
        echo -e "${YELLOW}To stop tunnel: Select option 6 from menu${NC}"
        return 0
    else
        echo -e "${RED}[✗] Failed to start Cloudflare tunnel${NC}"
        echo -e "${YELLOW}Error log:${NC}"
        tail -10 /tmp/cloudflare.log
        kill $TUNNEL_PID 2>/dev/null
        rm "$TUNNEL_PID_FILE"
        return 1
    fi
}

# Stop Cloudflare tunnel
stop_cloudflare() {
    if [ -f "$TUNNEL_PID_FILE" ]; then
        kill $(cat "$TUNNEL_PID_FILE") 2>/dev/null
        rm "$TUNNEL_PID_FILE"
        echo -e "${GREEN}[✓] Cloudflare tunnel stopped${NC}"
        echo -e "${YELLOW}[!] Website is now private (local only)${NC}"
    else
        # Kill any cloudflared processes
        pkill -f "cloudflared.*tunnel" && echo -e "${GREEN}[✓] Cloudflare tunnel stopped${NC}" || echo -e "${YELLOW}[!] No tunnel running${NC}"
    fi
}

# Edit HTML with nano
edit_html() {
    if [ -f "$SITE_DIR/index.html" ]; then
        echo -e "${GREEN}[+] Opening HTML editor (nano)${NC}"
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "nano shortcuts:"
        echo -e "  ${GREEN}Ctrl+O${NC} - Save"
        echo -e "  ${GREEN}Ctrl+X${NC} - Exit"
        echo -e "  ${GREEN}Ctrl+W${NC} - Search"
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        read -p "Press Enter to start editing..."
        nano "$SITE_DIR/index.html"
        echo -e "${GREEN}[✓] HTML updated! Refresh browser to see changes${NC}"
        
        # If tunnel is running, show the public URL again
        if [ -f "$TUNNEL_PID_FILE" ] && [ -f "$SITE_DIR/public_url.txt" ]; then
            PUBLIC_URL=$(cat "$SITE_DIR/public_url.txt")
            echo -e "${GREEN}Your public URL: $PUBLIC_URL${NC}"
        fi
    else
        echo -e "${RED}[✗] No website found. Create one first (option 1)${NC}"
    fi
}

# Show status
show_status() {
    clear
    echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     ${GREEN}KALI WEBSITE TOOL - STATUS${BLUE}              ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Local server status
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if [ -f "$SERVER_PID_FILE" ] && kill -0 $(cat "$SERVER_PID_FILE") 2>/dev/null; then
        echo -e "${GREEN}● LOCAL SERVER: RUNNING${NC}"
        echo -e "  Port: ${GREEN}$PORT${NC}"
        echo -e "  URL:  ${GREEN}http://localhost:$PORT${NC}"
        echo -e "  PID:  $(cat $SERVER_PID_FILE)"
    else
        echo -e "${RED}○ LOCAL SERVER: STOPPED${NC}"
    fi
    
    # Cloudflare status
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if [ -f "$TUNNEL_PID_FILE" ] && kill -0 $(cat "$TUNNEL_PID_FILE") 2>/dev/null; then
        echo -e "${GREEN}● CLOUDFLARE: ACTIVE 🌍${NC}"
        if [ -f "$SITE_DIR/public_url.txt" ]; then
            PUBLIC_URL=$(cat "$SITE_DIR/public_url.txt")
            if [ "$PUBLIC_URL" != "Local only" ]; then
                echo -e "  Public URL: ${GREEN}$PUBLIC_URL${NC}"
            fi
        fi
        echo -e "  Tunnel PID: $(cat $TUNNEL_PID_FILE)"
    else
        echo -e "${RED}○ CLOUDFLARE: INACTIVE${NC}"
    fi
    
    # Website info
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if [ -f "$SITE_DIR/index.html" ]; then
        echo -e "${GREEN}📄 WEBSITE FILES:${NC}"
        echo -e "  Location: $SITE_DIR"
        echo -e "  Main file: index.html"
        SIZE=$(du -sh "$SITE_DIR" 2>/dev/null | cut -f1)
        echo -e "  Size: $SIZE"
        echo -e "  Modified: $(stat -c %y "$SITE_DIR/index.html" 2>/dev/null | cut -d. -f1)"
    else
        echo -e "${RED}📄 No website created${NC}"
    fi
    
    # Quick actions
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}Quick actions:${NC}"
    if [ ! -f "$SERVER_PID_FILE" ]; then
        echo -e "  → Select ${GREEN}3${NC} to start server"
    elif [ ! -f "$TUNNEL_PID_FILE" ]; then
        echo -e "  → Select ${GREEN}5${NC} to make public with Cloudflare"
    else
        echo -e "  → Select ${GREEN}6${NC} to stop Cloudflare"
        echo -e "  → Select ${GREEN}4${NC} to stop server"
    fi
    echo -e "  → Select ${GREEN}2${NC} to edit HTML"
    echo ""
}

# Show menu
show_menu() {
    clear
    echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     ${GREEN}SIMPLE KALI WEBSITE TOOL${BLUE}              ║${NC}"
    echo -e "${BLUE}║        with Cloudflare Tunnel              ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${GREEN}1)${NC} Create/Reset Website"
    echo -e "  ${GREEN}2)${NC} Edit HTML with nano"
    echo -e "  ${GREEN}3)${NC} Start Local Server"
    echo -e "  ${GREEN}4)${NC} Stop Local Server"
    echo -e "  ${GREEN}5)${NC} Start Cloudflare (Make Public)"
    echo -e "  ${GREEN}6)${NC} Stop Cloudflare (Make Private)"
    echo -e "  ${GREEN}7)${NC} Show Status"
    echo -e "  ${GREEN}8)${NC} Exit"
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# Main function
main() {
    # Initial setup
    if [ ! -d "$SITE_DIR" ]; then
        echo -e "${YELLOW}[!] First time setup...${NC}"
        create_website
        echo ""
    fi
    
    while true; do
        show_menu
        read -p "Select option [1-8]: " choice
        
        case $choice in
            1)
                create_website
                ;;
            2)
                edit_html
                ;;
            3)
                start_local
                ;;
            4)
                stop_local
                ;;
            5)
                start_cloudflare
                ;;
            6)
                stop_cloudflare
                ;;
            7)
                show_status
                ;;
            8)
                echo -e "${YELLOW}[+] Cleaning up...${NC}"
                stop_cloudflare
                stop_local
                echo -e "${GREEN}[✓] All services stopped${NC}"
                echo -e "${GREEN}Goodbye!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}[✗] Invalid option${NC}"
                ;;
        esac
        
        echo ""
        read -p "Press Enter to continue..."
    done
}

# Run the script
main
