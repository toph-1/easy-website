#!/bin/bash

# Simple Website Tool for Kali
# Usage: ./site-tool.sh

# Colors for Kali (green on black theme)
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Config
SITE_DIR="$HOME/kali_site"
PORT="8080"
TUNNEL_PID_FILE="/tmp/cloudflare_tunnel.pid"
SERVER_PID_FILE="/tmp/local_server.pid"

# Check if running as root (common in Kali)
if [ "$EUID" -eq 0 ]; then 
    echo -e "${YELLOW}⚠️  Running as root${NC}"
fi

# Install cloudflared if needed
install_cloudflared() {
    if ! command -v cloudflared &> /dev/null; then
        echo -e "${YELLOW}[+] Installing cloudflared for Kali...${NC}"
        wget -q https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64
        chmod +x cloudflared-linux-amd64
        sudo mv cloudflared-linux-amd64 /usr/local/bin/cloudflared
        echo -e "${GREEN}[✓] Cloudflared installed${NC}"
    fi
}

# Create default website
create_website() {
    echo -e "${BLUE}[+] Creating website in $SITE_DIR${NC}"
    mkdir -p "$SITE_DIR"
    
    cat > "$SITE_DIR/index.html" << 'EOF'
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kali Site</title>
    <style>
        body {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            color: #00ff41;
            font-family: 'Courier New', monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            text-shadow: 0 0 5px #00ff41;
        }
        .container {
            text-align: center;
            border: 2px solid #00ff41;
            padding: 2rem;
            border-radius: 10px;
            background: rgba(0,0,0,0.8);
            box-shadow: 0 0 20px rgba(0,255,65,0.3);
        }
        h1 { font-size: 3em; margin: 0; }
        .status { color: #00ff41; animation: blink 1s infinite; }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .url { background: #000; padding: 10px; border-radius: 5px; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🐉 KALI WEBSITE</h1>
        <p>Status: <span class="status">● LIVE</span></p>
        <p>Serving from your Kali machine</p>
        <div class="url" id="url">Local: http://localhost:8080</div>
        <p><small>Press Ctrl+C to stop</small></p>
    </div>
    <script>
        setInterval(() => {
            fetch('/ping')
                .then(response => response.text())
                .catch(console.log);
        }, 30000);
    </script>
</body>
</html>
EOF
    
    # Add a hacker-style CSS
    cat > "$SITE_DIR/style.css" << 'EOF'
body { margin: 0; padding: 0; }
.hacker-text { color: #0f0; font-family: monospace; }
EOF
    
    echo -e "${GREEN}[✓] Website created at $SITE_DIR/index.html${NC}"
}

# Start local server
start_local() {
    if [ -f "$SERVER_PID_FILE" ] && kill -0 $(cat "$SERVER_PID_FILE") 2>/dev/null; then
        echo -e "${YELLOW}[!] Server already running${NC}"
        return 1
    fi
    
    cd "$SITE_DIR"
    
    # Use Python3 (built into Kali)
    if command -v python3 &> /dev/null; then
        python3 -m http.server $PORT > /tmp/local_server.log 2>&1 &
        echo $! > "$SERVER_PID_FILE"
        echo -e "${GREEN}[✓] Local server started on port $PORT${NC}"
        echo -e "${GREEN}[✓] Access at: http://localhost:$PORT${NC}"
    else
        echo -e "${RED}[✗] Python3 not found${NC}"
        return 1
    fi
}

# Stop local server
stop_local() {
    if [ -f "$SERVER_PID_FILE" ]; then
        kill $(cat "$SERVER_PID_FILE") 2>/dev/null
        rm "$SERVER_PID_FILE"
        echo -e "${GREEN}[✓] Local server stopped${NC}"
    else
        echo -e "${YELLOW}[!] No server running${NC}"
    fi
}

# Start Cloudflare tunnel
start_cloudflare() {
    if [ ! -f "$SERVER_PID_FILE" ]; then
        echo -e "${RED}[✗] Local server not running. Start it first!${NC}"
        return 1
    fi
    
    if [ -f "$TUNNEL_PID_FILE" ] && kill -0 $(cat "$TUNNEL_PID_FILE") 2>/dev/null; then
        echo -e "${YELLOW}[!] Cloudflare tunnel already running${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}[+] Starting Cloudflare tunnel...${NC}"
    
    # Start tunnel
    cloudflared tunnel --url http://localhost:$PORT > /tmp/cloudflare.log 2>&1 &
    echo $! > "$TUNNEL_PID_FILE"
    
    sleep 4
    
    # Get the public URL
    PUBLIC_URL=$(grep -o 'https://[-a-zA-Z0-9.]*trycloudflare.com' /tmp/cloudflare.log | head -1)
    
    if [ -n "$PUBLIC_URL" ]; then
        echo -e "${GREEN}════════════════════════════════════════${NC}"
        echo -e "${GREEN}🌍 WEBSITE IS PUBLIC!${NC}"
        echo -e "${GREEN}════════════════════════════════════════${NC}"
        echo -e "${YELLOW}Public URL: ${GREEN}$PUBLIC_URL${NC}"
        echo -e "${YELLOW}Local URL:  ${GREEN}http://localhost:$PORT${NC}"
        echo -e "${GREEN}════════════════════════════════════════${NC}"
        
        # Save URL for later
        echo "$PUBLIC_URL" > "$SITE_DIR/public_url.txt"
        
        # Show QR code (optional, cool for Kali)
        if command -v qrencode &> /dev/null; then
            echo -e "${YELLOW}QR Code for mobile access:${NC}"
            qrencode -t ansiutf8 "$PUBLIC_URL" 2>/dev/null
        fi
    else
        echo -e "${RED}[✗] Failed to start tunnel${NC}"
        echo -e "${YELLOW}Check log: /tmp/cloudflare.log${NC}"
        rm "$TUNNEL_PID_FILE"
        return 1
    fi
}

# Stop Cloudflare tunnel
stop_cloudflare() {
    if [ -f "$TUNNEL_PID_FILE" ]; then
        kill $(cat "$TUNNEL_PID_FILE") 2>/dev/null
        rm "$TUNNEL_PID_FILE"
        echo -e "${GREEN}[✓] Cloudflare tunnel stopped${NC}"
        echo -e "${YELLOW}[!] Website is now private again${NC}"
    else
        echo -e "${YELLOW}[!] No tunnel running${NC}"
    fi
}

# Edit HTML with nano
edit_html() {
    if [ -f "$SITE_DIR/index.html" ]; then
        echo -e "${GREEN}[+] Opening HTML editor (nano)${NC}"
        echo -e "${YELLOW}Tips:${NC}"
        echo "  - Ctrl+O to save"
        echo "  - Ctrl+X to exit"
        echo "  - Changes appear immediately on refresh"
        echo ""
        read -p "Press Enter to continue..."
        nano "$SITE_DIR/index.html"
        echo -e "${GREEN}[✓] HTML updated! Refresh your browser to see changes${NC}"
    else
        echo -e "${RED}[✗] No website found. Create one first!${NC}"
    fi
}

# Show status
show_status() {
    clear
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    echo -e "${GREEN}🐉 KALI WEBSITE STATUS${NC}"
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    
    # Local server status
    if [ -f "$SERVER_PID_FILE" ] && kill -0 $(cat "$SERVER_PID_FILE") 2>/dev/null; then
        echo -e "${GREEN}● Local Server: RUNNING${NC}"
        echo -e "  Port: $PORT"
        echo -e "  URL:  http://localhost:$PORT"
    else
        echo -e "${RED}○ Local Server: STOPPED${NC}"
    fi
    
    # Cloudflare status
    if [ -f "$TUNNEL_PID_FILE" ] && kill -0 $(cat "$TUNNEL_PID_FILE") 2>/dev/null; then
        echo -e "${GREEN}● Cloudflare: ACTIVE${NC}"
        if [ -f "$SITE_DIR/public_url.txt" ]; then
            PUBLIC_URL=$(cat "$SITE_DIR/public_url.txt")
            echo -e "  Public URL: ${GREEN}$PUBLIC_URL${NC}"
        fi
    else
        echo -e "${RED}○ Cloudflare: INACTIVE${NC}"
    fi
    
    # Website info
    if [ -f "$SITE_DIR/index.html" ]; then
        echo -e "${GREEN}📄 Website: $SITE_DIR/index.html${NC}"
        SIZE=$(du -h "$SITE_DIR/index.html" | cut -f1)
        echo -e "  Size: $SIZE"
    else
        echo -e "${RED}📄 No website created${NC}"
    fi
    
    echo -e "${BLUE}════════════════════════════════════════${NC}"
}

# Main menu
show_menu() {
    clear
    echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     ${GREEN}SIMPLE KALI WEBSITE TOOL${BLUE}        ║${NC}"
    echo -e "${BLUE}║        with Cloudflare Tunnel         ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}1)${NC} Create/Reset Website"
    echo -e "${GREEN}2)${NC} Edit HTML with nano"
    echo -e "${GREEN}3)${NC} Start Local Server"
    echo -e "${GREEN}4)${NC} Stop Local Server"
    echo -e "${GREEN}5)${NC} Start Cloudflare (Make Public)"
    echo -e "${GREEN}6)${NC} Stop Cloudflare (Make Private)"
    echo -e "${GREEN}7)${NC} Show Status"
    echo -e "${GREEN}8)${NC} Exit"
    echo ""
}

# Main
main() {
    # Check/create website directory
    if [ ! -d "$SITE_DIR" ]; then
        create_website
    fi
    
    # Install cloudflared
    install_cloudflared
    
    while true; do
        show_menu
        read -p "Choice [1-8]: " choice
        
        case $choice in
            1)
                create_website
                echo -e "${GREEN}[✓] Website ready!${NC}"
                ;;
            2)
                edit_html
                ;;
            3)
                start_local
                ;;
            4)
                stop_local
                ;;
            5)
                start_cloudflare
                ;;
            6)
                stop_cloudflare
                ;;
            7)
                show_status
                ;;
            8)
                # Cleanup on exit
                echo -e "${YELLOW}[+] Cleaning up...${NC}"
                stop_cloudflare
                stop_local
                echo -e "${GREEN}[✓] Goodbye!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}[✗] Invalid option${NC}"
                ;;
        esac
        
        echo ""
        read -p "Press Enter to continue..."
    done
}

# Run it
main
