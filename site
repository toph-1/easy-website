#!/bin/bash

# Website Manager with Cloudflare
# Usage: ./website-manager.sh

# Color codes for better UI
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
SITES_DIR="$HOME/websites"
CONFIG_FILE="$HOME/.website_manager.conf"
CLOUDFLARE_TUNNEL="/tmp/cloudflare_tunnel_$PROJECT_NAME.pid"

# Create necessary directories
mkdir -p "$SITES_DIR"

# Load or create config
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    else
        CLOUDFLARE_EMAIL=""
        CLOUDFLARE_API_KEY=""
        DEFAULT_SUBDOMAIN=""
    fi
}

# Save config
save_config() {
    cat > "$CONFIG_FILE" << EOF
CLOUDFLARE_EMAIL="$CLOUDFLARE_EMAIL"
CLOUDFLARE_API_KEY="$CLOUDFLARE_API_KEY"
DEFAULT_SUBDOMAIN="$DEFAULT_SUBDOMAIN"
EOF
}

# Check if Cloudflare is installed
check_cloudflare() {
    if ! command -v cloudflared &> /dev/null; then
        echo -e "${YELLOW}cloudflared not found. Installing...${NC}"
        if [[ "$OSTYPE" == "darwin"* ]]; then
            brew install cloudflared
        elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
            wget https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64
            chmod +x cloudflared-linux-amd64
            sudo mv cloudflared-linux-amd64 /usr/local/bin/cloudflared
        else
            echo -e "${RED}Please install cloudflared manually: https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation${NC}"
            return 1
        fi
    fi
    return 0
}

# Create a new website
create_website() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}Create New Website${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    read -p "Website name: " SITE_NAME
    SITE_PATH="$SITES_DIR/$SITE_NAME"
    
    if [ -d "$SITE_PATH" ]; then
        echo -e "${RED}Website already exists!${NC}"
        return 1
    fi
    
    mkdir -p "$SITE_PATH"
    
    echo -e "${YELLOW}Select website type:${NC}"
    echo "1) Static HTML site"
    echo "2) PHP site (requires PHP server)"
    echo "3) Node.js site (requires npm)"
    echo "4) Python/Flask site"
    read -p "Choice [1-4]: " SITE_TYPE
    
    case $SITE_TYPE in
        1)
            create_static_site "$SITE_PATH" "$SITE_NAME"
            ;;
        2)
            create_php_site "$SITE_PATH" "$SITE_NAME"
            ;;
        3)
            create_node_site "$SITE_PATH" "$SITE_NAME"
            ;;
        4)
            create_python_site "$SITE_PATH" "$SITE_NAME"
            ;;
        *)
            echo -e "${RED}Invalid choice${NC}"
            return 1
            ;;
    esac
    
    echo -e "${GREEN}✓ Website created at: $SITE_PATH${NC}"
    echo "$SITE_NAME:$SITE_PATH:$SITE_TYPE" >> "$SITES_DIR/sites.list"
}

# Create static HTML site
create_static_site() {
    local path=$1
    local name=$2
    
    cat > "$path/index.html" << EOF
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>$name - My Website</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .container {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            text-align: center;
        }
        h1 { color: #667eea; }
        .status { color: #4CAF50; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🚀 $name</h1>
        <p>Your website is <span class="status">LIVE!</span></p>
        <p>Deployed with Cloudflare Tunnel</p>
        <p id="timestamp"></p>
    </div>
    <script>
        document.getElementById('timestamp').innerHTML = 'Server time: ' + new Date().toLocaleString();
    </script>
</body>
</html>
EOF
    
    mkdir -p "$path/css" "$path/js" "$path/images"
    echo "/* Custom styles */" > "$path/css/style.css"
    echo "// Custom JavaScript" > "$path/js/script.js"
}

# Create PHP site
create_php_site() {
    local path=$1
    local name=$2
    
    cat > "$path/index.php" << EOF
<!DOCTYPE html>
<html>
<head>
    <title>$name</title>
    <style>
        body { font-family: Arial; margin: 50px; background: #f0f0f0; }
        .container { background: white; padding: 20px; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>PHP Site: $name</h1>
        <p>Server time: <?php echo date('Y-m-d H:i:s'); ?></p>
        <p>PHP Version: <?php echo phpversion(); ?></p>
    </div>
</body>
</html>
EOF
}

# Create Node.js site
create_node_site() {
    local path=$1
    local name=$2
    
    cat > "$path/package.json" << EOF
{
  "name": "$name",
  "version": "1.0.0",
  "description": "Node.js website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
EOF
    
    cat > "$path/server.js" << EOF
const express = require('express');
const app = express();
const port = 3000;

app.use(express.static('public'));

app.get('/', (req, res) => {
    res.send(\`
        <!DOCTYPE html>
        <html>
        <head><title>$name</title></head>
        <body style="font-family: Arial; text-align: center; margin-top: 50px;">
            <h1>🚀 Node.js Website: $name</h1>
            <p>Server running on port \${port}</p>
            <p>Time: \${new Date().toLocaleString()}</p>
        </body>
        </html>
    \`);
});

app.listen(port, () => {
    console.log(\`Server running at http://localhost:\${port}\`);
});
EOF
    
    mkdir -p "$path/public"
    cd "$path" && npm install 2>/dev/null
}

# Create Python/Flask site
create_python_site() {
    local path=$1
    local name=$2
    
    cat > "$path/app.py" << EOF
from flask import Flask
from datetime import datetime

app = Flask(__name__)

@app.route('/')
def home():
    return f'''
    <!DOCTYPE html>
    <html>
    <head><title>$name</title></head>
    <body style="font-family: Arial; text-align: center; margin-top: 50px;">
        <h1>🐍 Python/Flask Site: $name</h1>
        <p>Server time: {datetime.now()}</p>
        <p>Flask is running!</p>
    </body>
    </html>
    '''

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
EOF
    
    cat > "$path/requirements.txt" << EOF
flask==2.3.0
EOF
}

# Start a website locally
start_website() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}Start Website Locally${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    if [ ! -f "$SITES_DIR/sites.list" ]; then
        echo -e "${RED}No websites found. Create one first!${NC}"
        return 1
    fi
    
    echo -e "${YELLOW}Available websites:${NC}"
    cat -n "$SITES_DIR/sites.list"
    
    read -p "Select website number: " SITE_NUM
    SITE_INFO=$(sed -n "${SITE_NUM}p" "$SITES_DIR/sites.list")
    
    if [ -z "$SITE_INFO" ]; then
        echo -e "${RED}Invalid selection${NC}"
        return 1
    fi
    
    SITE_NAME=$(echo "$SITE_INFO" | cut -d':' -f1)
    SITE_PATH=$(echo "$SITE_INFO" | cut -d':' -f2)
    SITE_TYPE=$(echo "$SITE_INFO" | cut -d':' -f3)
    
    PORT=""
    case $SITE_TYPE in
        1)
            PORT=8000
            cd "$SITE_PATH" && python3 -m http.server $PORT > /tmp/site_${SITE_NAME}.log 2>&1 &
            echo $! > "/tmp/site_${SITE_NAME}.pid"
            echo -e "${GREEN}✓ Static site started on port $PORT${NC}"
            ;;
        2)
            PORT=8080
            cd "$SITE_PATH" && php -S localhost:$PORT > /tmp/site_${SITE_NAME}.log 2>&1 &
            echo $! > "/tmp/site_${SITE_NAME}.pid"
            echo -e "${GREEN}✓ PHP site started on port $PORT${NC}"
            ;;
        3)
            PORT=3000
            cd "$SITE_PATH" && npm start > /tmp/site_${SITE_NAME}.log 2>&1 &
            echo $! > "/tmp/site_${SITE_NAME}.pid"
            echo -e "${GREEN}✓ Node.js site started on port $PORT${NC}"
            ;;
        4)
            PORT=5000
            cd "$SITE_PATH" && python3 app.py > /tmp/site_${SITE_NAME}.log 2>&1 &
            echo $! > "/tmp/site_${SITE_NAME}.pid"
            echo -e "${GREEN}✓ Python site started on port $PORT${NC}"
            ;;
    esac
    
    echo "http://localhost:$PORT" > "/tmp/site_${SITE_NAME}.url"
    echo -e "${GREEN}✓ Website running at: http://localhost:$PORT${NC}"
}

# Stop a website
stop_website() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}Stop Website${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    echo -e "${YELLOW}Running websites:${NC}"
    for pidfile in /tmp/site_*.pid; do
        if [ -f "$pidfile" ]; then
            SITE=$(basename "$pidfile" .pid | sed 's/site_//')
            echo "- $SITE (PID: $(cat $pidfile))"
        fi
    done
    
    read -p "Enter website name to stop: " SITE_NAME
    
    if [ -f "/tmp/site_${SITE_NAME}.pid" ]; then
        PID=$(cat "/tmp/site_${SITE_NAME}.pid")
        kill $PID 2>/dev/null
        rm "/tmp/site_${SITE_NAME}.pid"
        rm "/tmp/site_${SITE_NAME}.url" 2>/dev/null
        
        # Also stop Cloudflare tunnel if running
        if [ -f "/tmp/cloudflare_${SITE_NAME}.pid" ]; then
            CF_PID=$(cat "/tmp/cloudflare_${SITE_NAME}.pid")
            kill $CF_PID 2>/dev/null
            rm "/tmp/cloudflare_${SITE_NAME}.pid"
            echo -e "${GREEN}✓ Cloudflare tunnel stopped${NC}"
        fi
        
        echo -e "${GREEN}✓ Website $SITE_NAME stopped${NC}"
    else
        echo -e "${RED}Website $SITE_NAME is not running${NC}"
    fi
}

# Deploy to Cloudflare (make public)
deploy_to_cloudflare() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}Deploy to Cloudflare (Make Public)${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    if ! check_cloudflare; then
        return 1
    fi
    
    echo -e "${YELLOW}Select website to deploy:${NC}"
    for pidfile in /tmp/site_*.pid; do
        if [ -f "$pidfile" ]; then
            SITE=$(basename "$pidfile" .pid | sed 's/site_//')
            URL=$(cat "/tmp/site_${SITE}.url" 2>/dev/null)
            echo "- $SITE ($URL)"
        fi
    done
    
    read -p "Enter website name: " SITE_NAME
    
    if [ ! -f "/tmp/site_${SITE_NAME}.pid" ]; then
        echo -e "${RED}Website $SITE_NAME is not running. Start it first!${NC}"
        return 1
    fi
    
    URL=$(cat "/tmp/site_${SITE_NAME}.url")
    PORT=$(echo "$URL" | grep -oP ':\K\d+')
    
    read -p "Custom subdomain (optional, press enter for random): " SUBDOMAIN
    
    if [ -z "$SUBDOMAIN" ]; then
        SUBDOMAIN="website-$(date +%s)"
    fi
    
    echo -e "${YELLOW}Starting Cloudflare tunnel...${NC}"
    
    # Start Cloudflare tunnel
    cloudflared tunnel --url "http://localhost:$PORT" > "/tmp/cloudflare_${SITE_NAME}.log" 2>&1 &
    CF_PID=$!
    echo $CF_PID > "/tmp/cloudflare_${SITE_NAME}.pid"
    
    sleep 3
    
    # Extract the public URL from logs
    PUBLIC_URL=$(grep -o 'https://[-a-zA-Z0-9.]*trycloudflare.com' "/tmp/cloudflare_${SITE_NAME}.log" | head -1)
    
    if [ -n "$PUBLIC_URL" ]; then
        echo -e "${GREEN}✓ Website is now PUBLIC!${NC}"
        echo -e "${GREEN}🔗 Public URL: $PUBLIC_URL${NC}"
        echo "$PUBLIC_URL" > "/tmp/site_${SITE_NAME}.public_url"
        
        echo -e "${YELLOW}To stop the tunnel, stop the website or run:${NC}"
        echo "  ./website-manager.sh -> Stop Website -> $SITE_NAME"
    else
        echo -e "${RED}Failed to start tunnel. Check logs: /tmp/cloudflare_${SITE_NAME}.log${NC}"
        kill $CF_PID 2>/dev/null
        rm "/tmp/cloudflare_${SITE_NAME}.pid"
        return 1
    fi
}

# Show status of all websites
show_status() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}Website Status${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    echo -e "\n${YELLOW}Local Servers:${NC}"
    for pidfile in /tmp/site_*.pid; do
        if [ -f "$pidfile" ]; then
            SITE=$(basename "$pidfile" .pid | sed 's/site_//')
            PID=$(cat "$pidfile")
            URL=$(cat "/tmp/site_${SITE}.url" 2>/dev/null)
            PUBLIC=$(cat "/tmp/site_${SITE}.public_url" 2>/dev/null)
            
            echo -e "  ${GREEN}●${NC} $SITE (PID: $PID)"
            echo -e "    Local: $URL"
            [ -n "$PUBLIC" ] && echo -e "    🌍 Public: $PUBLIC"
        fi
    done
    
    if [ ! -f /tmp/site_*.pid ] 2>/dev/null; then
        echo -e "  ${RED}No websites running${NC}"
    fi
    
    echo -e "\n${YELLOW}Available Websites:${NC}"
    if [ -f "$SITES_DIR/sites.list" ]; then
        cat "$SITES_DIR/sites.list" | while IFS=':' read name path type; do
            echo -e "  📁 $name ($(basename $path)) - Type: $type"
        done
    else
        echo -e "  No websites created yet"
    fi
    echo ""
}

# Main menu
show_menu() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}🌐 WEBSITE MANAGER WITH CLOUDFLARE${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "1) Create New Website"
    echo "2) Start Website (Local)"
    echo "3) Stop Website"
    echo "4) Deploy to Cloudflare (Make Public)"
    echo "5) Show Status"
    echo "6) Configure Cloudflare Settings"
    echo "7) Exit"
    echo ""
}

# Main loop
main() {
    load_config
    
    while true; do
        show_menu
        read -p "Select option [1-7]: " choice
        
        case $choice in
            1)
                create_website
                ;;
            2)
                start_website
                ;;
            3)
                stop_website
                ;;
            4)
                deploy_to_cloudflare
                ;;
            5)
                show_status
                ;;
            6)
                echo -e "${YELLOW}Cloudflare configuration (optional for advanced features)${NC}"
                read -p "Cloudflare Email: " CLOUDFLARE_EMAIL
                read -p "Cloudflare API Key: " CLOUDFLARE_API_KEY
                read -p "Default subdomain (yourdomain.com): " DEFAULT_SUBDOMAIN
                save_config
                echo -e "${GREEN}Configuration saved!${NC}"
                ;;
            7)
                echo -e "${GREEN}Goodbye!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid option${NC}"
                ;;
        esac
        
        echo ""
        read -p "Press enter to continue..."
    done
}

# Run the script
main
