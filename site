#!/bin/bash
# site-tool.sh - Complete working version for Kali with Cloudflare fix

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SITE_DIR="$HOME/kali_site"
PORT="8080"
TUNNEL_PID_FILE="/tmp/cloudflare_tunnel.pid"
SERVER_PID_FILE="/tmp/local_server.pid"

# Fix DNS for Cloudflare
fix_dns() {
    echo -e "${YELLOW}[+] Configuring DNS for Cloudflare...${NC}"
    
    # Backup original
    sudo cp /etc/resolv.conf /etc/resolv.conf.backup 2>/dev/null
    
    # Set Cloudflare DNS
    echo "nameserver 1.1.1.1" | sudo tee /etc/resolv.conf > /dev/null
    echo "nameserver 1.0.0.1" | sudo tee -a /etc/resolv.conf > /dev/null
    
    # Make immutable to prevent systemd from overwriting
    sudo chattr +i /etc/resolv.conf 2>/dev/null
    
    # Test DNS
    if nslookup trycloudflare.com 1.1.1.1 > /dev/null 2>&1; then
        echo -e "${GREEN}[✓] DNS configured successfully${NC}"
        return 0
    else
        echo -e "${RED}[✗] DNS still having issues${NC}"
        return 1
    fi
}

# Install cloudflared for Kali
install_cloudflared() {
    if command -v cloudflared &> /dev/null; then
        echo -e "${GREEN}[✓] cloudflared is installed${NC}"
        return 0
    fi
    
    echo -e "${YELLOW}[+] Installing cloudflared for Kali...${NC}"
    
    # Remove any broken installation
    sudo apt remove cloudflared -y 2>/dev/null
    
    # Download latest binary
    wget -q --show-progress https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -O /tmp/cloudflared
    
    if [ ! -f "/tmp/cloudflared" ]; then
        echo -e "${RED}[✗] Download failed. Using alternative method...${NC}"
        curl -L -o /tmp/cloudflared https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64
    fi
    
    # Install
    chmod +x /tmp/cloudflared
    sudo mv /tmp/cloudflared /usr/local/bin/cloudflared
    
    # Verify
    if cloudflared --version &>/dev/null; then
        echo -e "${GREEN}[✓] cloudflared installed successfully${NC}"
        return 0
    else
        echo -e "${RED}[✗] Installation failed${NC}"
        return 1
    fi
}

